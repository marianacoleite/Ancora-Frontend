# URL do backend (Express). Predefinição local típica: http://localhost:3000
# Com VITE_BACKEND_URL definida: JWT em sessionStorage, POST /api/v1/auth/login|register, GET /api/v1/auth/me, GET /api/v1/app-data.
# Sem ela: modo local (dados em localStorage + login demo interno).
# VITE_BACKEND_URL=http://localhost:3000
# VITE_BACKEND_URL=https://ancora-backend-production.up.railway.app

# Opcional: pré-preenche o formulário de login em dev (não coloques segredos reais — VITE_* é exposto no cliente).
VITE_USUARIO=
VITE_SENHA=
